generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma does not allow using env() for the `provider` field.  You must
  // set the provider here directly and regenerate the client if you change
  // database engines.  The application will still read the connection URL
  // (DATABASE_URL) from the environment, which is built automatically based
  // on the DB_* variables in server.js.
  //
  // Common values:
  //   "mysql"          // MySQL or MariaDB
  //   "postgresql"     // PostgreSQL
  //   "sqlite"         // SQLite
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ChatSession {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  expiresAt DateTime
  isClosed  Boolean  @default(false)
  media     Media[]
}

model Media {
  id        String   @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  filename  String
  fileType  String
  createdAt DateTime @default(now())
}
