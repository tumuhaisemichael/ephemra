generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model ChatSession {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  expiresAt DateTime
  isClosed  Boolean  @default(false)
  media     Media[]
}

model Media {
  id        String   @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  filename  String
  fileType  String
  createdAt DateTime @default(now())
}
